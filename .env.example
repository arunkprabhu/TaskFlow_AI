# ─────────────────────────────────────────────
#  meetingtotask — Environment Variables
#  Copy to .env and fill in real values
# ─────────────────────────────────────────────

# ── Ollama ────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b

# ── Monday.com ────────────────────────────────
MONDAY_API_TOKEN=your_monday_api_token_here
MONDAY_BOARD_ID=your_board_id_here

# ── Backend ───────────────────────────────────
CORS_ORIGINS=https://yourdomain.com,http://localhost:5173
LOG_LEVEL=info
ENVIRONMENT=production

# ── Docker images (optional overrides) ───────
# BACKEND_IMAGE=ghcr.io/your-org/meetingtotask/backend:latest
# FRONTEND_IMAGE=ghcr.io/your-org/meetingtotask/frontend:latest
